{
  "experiment": "act_chunk_vr_pretrain_lite",
  "description": "Stage 1: Pretrain ACT-Chunk-Lite on VR data (collector5-8) - smaller model for CPU",
  "data": {
    "data_sources": [
      {
        "name": "collector5",
        "episodes_jsonl": "../data_collector/collector5/vr-demonstrations-episodes-20260325_111750.jsonl",
        "events_jsonl": "../data_collector/collector5/vr-demonstrations-events-20260325_111751.jsonl"
      },
      {
        "name": "collector6",
        "episodes_jsonl": "../data_collector/collector6/vr-demonstrations-episodes-20260408_203644.jsonl",
        "events_jsonl": "../data_collector/collector6/vr-demonstrations-events-20260408_203645.jsonl"
      },
      {
        "name": "collector7",
        "episodes_jsonl": "../data_collector/collector7/vr-demonstrations-episodes-20260409_173553.jsonl",
        "events_jsonl": "../data_collector/collector7/vr-demonstrations-events-20260409_173553.jsonl"
      },
      {
        "name": "collector8",
        "episodes_jsonl": "../data_collector/collector8/vr-demonstrations-episodes-20260409_183018.jsonl",
        "events_jsonl": "../data_collector/collector8/vr-demonstrations-events-20260409_183020.jsonl"
      }
    ],
    "g1_joint_names": [
      "left_shoulder_pitch_joint",
      "left_shoulder_roll_joint",
      "left_shoulder_yaw_joint",
      "left_elbow_joint",
      "right_shoulder_pitch_joint",
      "right_shoulder_roll_joint",
      "right_shoulder_yaw_joint",
      "right_elbow_joint"
    ],
    "allowed_outcomes": ["success", "timeout"],
    "train_split": 0.85,
    "seq_len": 10,
    "obs_clip_z": 8.0,
    "act_clip_z": 8.0,
    "max_abs_g1_velocity": 15.0,
    "max_abs_g1_delta": 1.5,
    "sample_weighting": {
      "success_bonus": 0.5,
      "near_target_bonus": 0.3,
      "near_target_threshold": 0.25,
      "idle_discount": 0.2,
      "moving_bonus": 0.1,
      "approaching_bonus": 0.3,
      "max_weight": 3.0
    }
  },
  "train": {
    "seed": 42,
    "epochs": 300,
    "batch_size": 256,
    "lr": 3e-4,
    "weight_decay": 1e-4,
    "grad_clip_norm": 1.0,
    "early_stop_patience": 40,
    "success_loss_weight": 0.1,
    "obs_noise_std": 0.03,
    "lr_scheduler": "cosine"
  },
  "act_chunk": {
    "chunk_size": 5,
    "d_model": 128,
    "nhead": 4,
    "num_encoder_layers": 3,
    "num_decoder_layers": 1,
    "dim_feedforward": 256,
    "dropout": 0.1,
    "use_cvae": false,
    "latent_dim": 16,
    "kl_weight": 0.01
  }
}
