{
  "experiment": "g1_reach_c6_c8_only_200ep",
  "data": {
    "data_sources": [
      {
        "name": "collector6",
        "episodes_jsonl": "../data_collector/collector6/vr-demonstrations-episodes-20260408_203644.jsonl",
        "events_jsonl": "../data_collector/collector6/vr-demonstrations-events-20260408_203645.jsonl"
      },
      {
        "name": "collector8",
        "episodes_jsonl": "../data_collector/collector8/vr-demonstrations-episodes-20260409_183018.jsonl",
        "events_jsonl": "../data_collector/collector8/vr-demonstrations-events-20260409_183020.jsonl"
      }
    ],
    "g1_joint_names": [
      "left_shoulder_pitch_joint",
      "left_shoulder_roll_joint",
      "left_shoulder_yaw_joint",
      "left_elbow_joint",
      "right_shoulder_pitch_joint",
      "right_shoulder_roll_joint",
      "right_shoulder_yaw_joint",
      "right_elbow_joint"
    ],
    "allowed_outcomes": ["success", "timeout"],
    "train_split": 0.85,
    "seq_len": 16,
    "obs_clip_z": 8.0,
    "act_clip_z": 8.0,
    "max_abs_g1_velocity": 10.0,
    "max_abs_g1_delta": 1.0,
    "sample_weighting": {
      "success_bonus": 0.5,
      "near_target_bonus": 0.3,
      "near_target_threshold": 0.25,
      "idle_discount": 0.3,
      "moving_bonus": 0.15,
      "approaching_bonus": 0.25,
      "max_weight": 3.0
    }
  },
  "train": {
    "seed": 42,
    "epochs": 200,
    "batch_size": 256,
    "lr": 3e-4,
    "weight_decay": 1e-5,
    "grad_clip_norm": 1.0,
    "early_stop_patience": 30,
    "success_loss_weight": 0.2,
    "lr_scheduler": "cosine"
  },
  "bc": {
    "hidden_dims": [256, 256, 128],
    "dropout": 0.1
  },
  "act": {
    "d_model": 256,
    "nhead": 8,
    "num_layers": 4,
    "dim_feedforward": 512,
    "dropout": 0.1,
    "use_residual_action": true
  }
}
