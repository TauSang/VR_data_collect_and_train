{
  "experiment": "act_chunk_mujoco_finetune",
  "description": "Stage 2: Finetune ACT-Chunk on MuJoCo expert data for precision correction",
  "data": {
    "data_sources": [
      {
        "name": "mujoco_expert_v4",
        "episodes_jsonl": "../data_collector/mujoco_expert_v4/episodes.jsonl",
        "events_jsonl": "../data_collector/mujoco_expert_v4/events.jsonl"
      }
    ],
    "g1_joint_names": [
      "left_shoulder_pitch_joint",
      "left_shoulder_roll_joint",
      "left_shoulder_yaw_joint",
      "left_elbow_joint",
      "right_shoulder_pitch_joint",
      "right_shoulder_roll_joint",
      "right_shoulder_yaw_joint",
      "right_elbow_joint"
    ],
    "allowed_outcomes": ["success", "timeout"],
    "train_split": 0.85,
    "seq_len": 10,
    "obs_clip_z": 8.0,
    "act_clip_z": 8.0,
    "max_abs_g1_velocity": 10.0,
    "max_abs_g1_delta": 1.0,
    "sample_weighting": {
      "success_bonus": 0.5,
      "near_target_bonus": 0.3,
      "near_target_threshold": 0.25,
      "idle_discount": 0.3,
      "moving_bonus": 0.15,
      "approaching_bonus": 0.25,
      "max_weight": 3.0
    }
  },
  "train": {
    "seed": 42,
    "epochs": 200,
    "batch_size": 256,
    "lr": 5e-5,
    "weight_decay": 1e-4,
    "grad_clip_norm": 1.0,
    "early_stop_patience": 30,
    "success_loss_weight": 0.2,
    "obs_noise_std": 0.03,
    "lr_scheduler": "cosine"
  },
  "act_chunk": {
    "chunk_size": 10,
    "d_model": 256,
    "nhead": 8,
    "num_encoder_layers": 4,
    "num_decoder_layers": 2,
    "dim_feedforward": 512,
    "dropout": 0.05,
    "use_cvae": false,
    "latent_dim": 32,
    "kl_weight": 0.01
  }
}
