{
    "experiment": "20260424_v3_phase1_mj_regularized",
    "description": "v3 Phase 1: fix v2 overfitting at ep 6. Revert hidden_dims to [512,512,256] (proven capacity), strong obs_noise 0.08, dropout 0.2, WD 3e-4, lr 2e-4 with 10-ep warmup. 500 ep / patience 200 so cosine can fully anneal. MSE, no outcome filter, no target jitter.",
    "data": {
        "data_sources": [
            {
                "name": "mujoco_expert_v4",
                "episodes_jsonl": "../data_collector/mujoco_expert_v4/episodes.jsonl",
                "events_jsonl": "../data_collector/mujoco_expert_v4/events.jsonl",
                "source_id": 0
            }
        ],
        "g1_joint_names": [
            "left_shoulder_pitch_joint", "left_shoulder_roll_joint",
            "left_shoulder_yaw_joint", "left_elbow_joint",
            "right_shoulder_pitch_joint", "right_shoulder_roll_joint",
            "right_shoulder_yaw_joint", "right_elbow_joint"
        ],
        "allowed_outcomes": ["success", "timeout"],
        "train_split": 0.9,
        "seq_len": 1,
        "stride": 1,
        "obs_clip_z": 8.0,
        "act_clip_z": 8.0,
        "max_abs_g1_velocity": 10.0,
        "max_abs_g1_delta": 1.0,
        "sample_weighting": {
            "success_bonus": 0.5,
            "near_target_bonus": 0.3,
            "near_target_threshold": 0.25,
            "idle_discount": 0.3,
            "moving_bonus": 0.15,
            "approaching_bonus": 0.25,
            "max_weight": 3.0
        }
    },
    "train": {
        "seed": 42,
        "epochs": 500,
        "batch_size": 512,
        "lr": 2e-4,
        "weight_decay": 3e-4,
        "grad_clip_norm": 1.0,
        "early_stop_patience": 200,
        "success_loss_weight": 0.2,
        "obs_noise_std": 0.08,
        "lr_scheduler": "cosine",
        "lr_warmup_epochs": 10,
        "loss_type": "mse",
        "save_topk": 3
    },
    "act_chunk": {
        "backbone": "mlp_film",
        "chunk_size": 5,
        "hidden_dims": [512, 512, 256],
        "dropout": 0.2,
        "num_domains": 2,
        "cond_dim": 16,
        "default_domain_id": 0
    }
}
