{
    "experiment": "mixed_film",
    "description": "Domain-adaptive FiLM on mixed weak-MJ + VR-aligned. Innovation: VR absorbs its domain bias into FiLM embedding; inference always uses domain=0 (MuJoCo).",
    "data": {
        "data_sources": [
            {
                "name": "mujoco_expert_v4_weak",
                "episodes_jsonl": "../data_collector/mujoco_expert_v4_weak/episodes.jsonl",
                "events_jsonl": "../data_collector/mujoco_expert_v4_weak/events.jsonl",
                "source_id": 0
            },
            {
                "name": "collector10_aligned",
                "episodes_jsonl": "../data_collector/collector10_aligned/episodes.jsonl",
                "events_jsonl": "../data_collector/collector10_aligned/events.jsonl",
                "source_id": 1
            }
        ],
        "g1_joint_names": [
            "left_shoulder_pitch_joint", "left_shoulder_roll_joint",
            "left_shoulder_yaw_joint", "left_elbow_joint",
            "right_shoulder_pitch_joint", "right_shoulder_roll_joint",
            "right_shoulder_yaw_joint", "right_elbow_joint"
        ],
        "allowed_outcomes": ["success", "timeout"],
        "train_split": 0.85,
        "seq_len": 1,
        "stride": 1,
        "obs_clip_z": 8.0,
        "act_clip_z": 8.0,
        "max_abs_g1_velocity": 10.0,
        "max_abs_g1_delta": 1.0,
        "sample_weighting": {
            "success_bonus": 0.5,
            "near_target_bonus": 0.3,
            "near_target_threshold": 0.25,
            "idle_discount": 0.3,
            "moving_bonus": 0.15,
            "approaching_bonus": 0.25,
            "max_weight": 3.0
        }
    },
    "train": {
        "seed": 42,
        "epochs": 80,
        "batch_size": 256,
        "lr": 3e-4,
        "weight_decay": 1e-4,
        "grad_clip_norm": 1.0,
        "early_stop_patience": 20,
        "success_loss_weight": 0.2,
        "obs_noise_std": 0.03,
        "lr_scheduler": "cosine"
    },
    "act_chunk": {
        "backbone": "mlp_film",
        "chunk_size": 5,
        "hidden_dims": [256, 256, 128],
        "dropout": 0.1,
        "num_domains": 2,
        "cond_dim": 16,
        "default_domain_id": 0
    }
}
