{
    "experiment": "mixed_finetune_low_lr",
    "description": "Mixed VR+MuJoCo finetune with very low lr (1e-6) to avoid catastrophic divergence",
    "data": {
        "data_sources": [
            {
                "name": "collector6",
                "episodes_jsonl": "../data_collector/collector6/vr-demonstrations-episodes-20260408_203644.jsonl",
                "events_jsonl": "../data_collector/collector6/vr-demonstrations-events-20260408_203645.jsonl"
            },
            {
                "name": "collector7",
                "episodes_jsonl": "../data_collector/collector7/vr-demonstrations-episodes-20260409_173553.jsonl",
                "events_jsonl": "../data_collector/collector7/vr-demonstrations-events-20260409_173553.jsonl"
            },
            {
                "name": "collector8",
                "episodes_jsonl": "../data_collector/collector8/vr-demonstrations-episodes-20260409_183018.jsonl",
                "events_jsonl": "../data_collector/collector8/vr-demonstrations-events-20260409_183020.jsonl"
            },
            {
                "name": "mujoco_expert_v4",
                "episodes_jsonl": "../data_collector/mujoco_expert_v4/episodes.jsonl",
                "events_jsonl": "../data_collector/mujoco_expert_v4/events.jsonl"
            }
        ],
        "g1_joint_names": [
            "left_shoulder_pitch_joint", "left_shoulder_roll_joint",
            "left_shoulder_yaw_joint", "left_elbow_joint",
            "right_shoulder_pitch_joint", "right_shoulder_roll_joint",
            "right_shoulder_yaw_joint", "right_elbow_joint"
        ],
        "allowed_outcomes": ["success", "timeout"],
        "train_split": 0.85,
        "seq_len": 1,
        "stride": 1,
        "obs_clip_z": 8.0,
        "act_clip_z": 8.0,
        "max_abs_g1_velocity": 10.0,
        "max_abs_g1_delta": 1.0,
        "sample_weighting": {
            "success_bonus": 0.5,
            "near_target_bonus": 0.3,
            "near_target_threshold": 0.25,
            "idle_discount": 0.3,
            "moving_bonus": 0.15,
            "approaching_bonus": 0.25,
            "max_weight": 3.0
        }
    },
    "train": {
        "seed": 42,
        "epochs": 200,
        "batch_size": 512,
        "lr": 1e-6,
        "weight_decay": 1e-4,
        "lr_scheduler": "cosine",
        "warmup_epochs": 5,
        "grad_clip_norm": 1.0,
        "early_stop_patience": 40,
        "obs_noise_std": 0.01,
        "success_loss_weight": 0.2,
        "loss_fn": "mse"
    },
    "act_chunk": {
        "backbone": "mlp",
        "hidden_dims": [256, 256, 128],
        "chunk_size": 5,
        "dropout": 0.1,
        "kl_weight": 0.0
    }
}
